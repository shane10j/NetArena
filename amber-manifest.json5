{
  manifest_version: "0.3.0",

  config_schema: {
    type: "object",
    properties: {
      image: {
        type: "string",
        default: "ghcr.io/<your-username>/<your-repo-name>:latest",
      },
      model_name: { type: "string", default: "gpt-4.1" },
      litellm_api_key: { type: "string", secret: true },
      litellm_api_base_url: { type: "string" },
      litellm_api_version: { type: "string" },
      log_level: { type: "string", default: "INFO" },
    },
    additionalProperties: false,
  },

  slots: {
    llm: { kind: "llm", optional: true },
  },

  components: {
    planner: {
      manifest: "./manifests/purple-agent-component.json5",
      config: {
        image: "${config.image}",
        role: "planner",
        model_name: "${config.model_name}",
        litellm_api_key: "${config.litellm_api_key}",
        litellm_api_base_url: "${config.litellm_api_base_url}",
        litellm_api_version: "${config.litellm_api_version}",
        log_level: "${config.log_level}",
      },
    },
    verifier: {
      manifest: "./manifests/purple-agent-component.json5",
      config: {
        image: "${config.image}",
        role: "verifier",
        model_name: "${config.model_name}",
        litellm_api_key: "${config.litellm_api_key}",
        litellm_api_base_url: "${config.litellm_api_base_url}",
        litellm_api_version: "${config.litellm_api_version}",
        log_level: "${config.log_level}",
      },
    },
    coordinator: {
      manifest: "./manifests/purple-agent-component.json5",
      config: {
        image: "${config.image}",
        role: "coordinator",
        model_name: "${config.model_name}",
        litellm_api_key: "${config.litellm_api_key}",
        litellm_api_base_url: "${config.litellm_api_base_url}",
        litellm_api_version: "${config.litellm_api_version}",
        log_level: "${config.log_level}",
      },
    },
  },

  bindings: [
    { to: "#planner.llm", from: "slots.llm", weak: true },
    { to: "#verifier.llm", from: "slots.llm", weak: true },
    { to: "#coordinator.llm", from: "slots.llm", weak: true },
    { to: "#coordinator.planner", from: "#planner.a2a" },
    { to: "#coordinator.verifier", from: "#verifier.a2a" },
  ],

  exports: {
    a2a: "#coordinator.a2a",
  },
}
